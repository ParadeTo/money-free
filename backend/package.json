{
  "name": "stock-analysis-backend",
  "version": "0.1.0",
  "description": "Stock Analysis Tool Backend - Node.js + Nest.js + Prisma + SQLite",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node src/scripts/seed.ts",
    "create-test-user": "ts-node src/scripts/create-test-user.ts",
    "test:tushare": "ts-node src/scripts/test-tushare.ts",
    "calculate-vcp": "ts-node src/scripts/calculate-vcp.ts",
    "calculate-vcp:hk": "ts-node src/scripts/calculate-vcp.ts --markets HK",
    "calculate-vcp:us": "ts-node src/scripts/calculate-vcp.ts --markets US",
    "calculate-vcp:all": "ts-node src/scripts/calculate-vcp.ts --markets SH,SZ,HK,US",
    "show-vcp-pullback": "ts-node src/scripts/show-vcp-pullback.ts",
    "show-all-vcp": "ts-node src/scripts/show-all-vcp.ts",
    "analyze-stock": "ts-node src/scripts/analyze-stock-vcp.ts",
    "export-vcp": "ts-node src/scripts/export-vcp-pullback.ts",
    "export-all-vcp": "ts-node src/scripts/export-all-vcp.ts",
    "export-all-vcp:hk": "ts-node src/scripts/export-all-vcp.ts --markets HK",
    "export-all-vcp:us": "ts-node src/scripts/export-all-vcp.ts --markets US",
    "show-vcp-early": "ts-node src/scripts/show-vcp-early-stage.ts",
    "export-vcp-early": "ts-node src/scripts/export-vcp-early-stage.ts",
    "import-hk": "ts-node src/scripts/import-hk-stocks.ts",
    "import-us": "ts-node src/scripts/import-us-stocks.ts",
    "update-index": "ts-node src/scripts/update-index-composition.ts",
    "test:import-hk": "ts-node src/scripts/test-import-hk.ts",
    "test:import-us": "ts-node src/scripts/test-import-us.ts",
    "status": "ts-node src/scripts/status-report.ts",
    "verify-import": "ts-node src/scripts/verify-import.ts",
    "quick-import": "ts-node src/scripts/quick-import-sample.ts",
    "update-hk-us": "ts-node src/scripts/incremental-update-hk-us.ts",
    "update-hk": "ts-node src/scripts/incremental-update-hk-us.ts --markets HK",
    "update-us": "ts-node src/scripts/incremental-update-hk-us.ts --markets US",
    "calc-indicators": "ts-node src/scripts/recalculate-indicators.ts",
    "calc-indicators:hk": "ts-node src/scripts/recalculate-indicators.ts --markets HK",
    "calc-indicators:us": "ts-node src/scripts/recalculate-indicators.ts --markets US",
    "calc-indicators:hk-us": "ts-node src/scripts/recalculate-indicators.ts --markets HK,US",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.0",
    "@nestjs/bull": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^5.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.11.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "commander": "^14.0.3",
    "p-limit": "^3.1.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "technicalindicators": "^3.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@prisma/client": "^6.19.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.35",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "prisma": "^6.19.2",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
